APP_NAME=TaskOrchestrator
APP_ENV=development
APP_PORT=8000
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/taskdb
DATABASE_SYNC_URL=postgresql://postgres:postgres@db:5432/taskdb

# Redis / Celery broker
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Security
SECRET_KEY=change_this_to_a_secure_random_string_min_32_chars
API_KEY=dev-api-key-change-in-production

# Celery config
CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF=60
TASK_SOFT_TIME_LIMIT=300
TASK_TIME_LIMIT=600

# Flower monitoring
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:admin
